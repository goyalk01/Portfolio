# Gemini API Key for Document Processing & Analysis
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Supabase Database URL (Phase 6 Database Migration)
DATABASE_URL=postgresql://postgres:password@db.supabase.co:5432/postgres

# Optional: GitHub PAT for auto-committing updated JSON data
GITHUB_PAT=your_github_personal_access_token
